# ============================================================
# Attendance & Salary Tracker v6.2.1 — Environment Variables
# ============================================================
# نسخ هذا الملف إلى .env وإضافة القيم

# Supabase Project URL (من: Settings → API → Project URL)
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Supabase Anon Key (من: Settings → API → anon/public)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ملاحظة:
# - التطبيق يعمل بدون هذه المتغيرات في وضع offline (localStorage)
# - لتفعيل المزامنة السحابية، أضف القيم الصحيحة
